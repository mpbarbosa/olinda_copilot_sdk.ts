{
  "name": "olinda_copilot_sdk.ts",
  "version": "0.5.3",
  "description": "TypeScript Wrapper Library for GitHub Copilot SDK",
  "main": "dist/src/index.js",
  "types": "dist/types/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/src/index.js"
    }
  },
  "scripts": {
    "prepare": "npm run build && npm run build:esm",
    "build": "tsc --project tsconfig.json",
    "build:esm": "tsc --project tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "start": "node dist/src/index.js",
    "test": "jest --coverage --testPathPattern='test/(core|integration|utils|lib|index)' --passWithNoTests",
    "test:core": "jest --testPathPattern='test/(core|index)' --passWithNoTests",
    "test:utils": "jest --testPathPattern='test/utils' --passWithNoTests",
    "test:integration": "jest --testPathPattern='test/integration' --passWithNoTests",
    "test:watch": "jest --watch --testPathPattern='test/(core|integration|utils|lib|index)'",
    "test:coverage": "jest --coverage --testPathPattern='test/(core|integration|utils|lib|index)'",
    "test:verbose": "jest --verbose --testPathPattern='test/(core|integration|utils|lib|index)'",
    "test:docker": "bash scripts/run-tests-docker.sh",
    "bench": "jest --testPathPattern='test/benchmarks' --verbose --passWithNoTests",
    "validate": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore dist",
    "lint:md:fix": "markdownlint '**/*.md' --ignore node_modules --ignore dist --fix",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "copilot",
    "github",
    "sdk",
    "typescript",
    "ai",
    "llm"
  ],
  "author": "Marcelo Pereira Barbosa",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "homepage": "https://github.com/mpbarbosa/olinda_copilot_sdk.ts#readme",
  "bugs": {
    "url": "https://github.com/mpbarbosa/olinda_copilot_sdk.ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpbarbosa/olinda_copilot_sdk.ts.git"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "olinda_utils.js": "https://github.com/mpbarbosa/olinda_utils.js/archive/refs/tags/v0.3.16.tar.gz"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.19.37",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "markdownlint-cli": "0.48.0",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  },
  "private": true
}
